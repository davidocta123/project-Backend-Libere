generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  // directUrl = env("DATABASE_DIRECT_URL")
}

model Category {
  id      Int      @id @default(autoincrement())
  name    String   @unique
  books   Book[]
  layouts LibraryLayout[] @relation("LayoutCategories")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Book {
  id        Int      @id @default(autoincrement())
  title     String
  author    String
  publisher String
  description String
  publishedYear Int
  isbn      String   @unique
  pageCount Int
  isHidden  Boolean  @default(false)

  fileKey String
  fileName String
  thumbnail String?
  
  categoryId Int
  category   Category @relation(fields: [categoryId], references: [id])
  layouts    LibraryLayout[] @relation("FeaturedBooks")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model LibraryLayout {
  id       Int     @id @default(autoincrement())
  heroText String?
  heroImg  String?
  
  featuredBooks Book[]     @relation("FeaturedBooks")
  categories    Category[] @relation("LayoutCategories")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

